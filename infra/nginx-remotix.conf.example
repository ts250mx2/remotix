# Remotix detras de tu propio Nginx (frontal TLS) — modo hibrido.
#
# Nginx sirve la consola web (estatica, compilada en /var/www/remotix) y hace
# proxy de la API, los WebSockets y las descargas al contenedor `server`
# (escuchando solo en 127.0.0.1:8080 via docker-compose.nginx.yml).
#
# Pasos:
#   1) Copia este archivo a /etc/nginx/sites-available/remotix.hlsistemas.com
#      (en CentOS/RHEL: /etc/nginx/conf.d/remotix.conf)
#   2) Ajusta server_name y root si tu dominio o ruta cambian.
#   3) sudo ln -s .../sites-available/... /etc/nginx/sites-enabled/   (Debian/Ubuntu)
#   4) sudo nginx -t && sudo systemctl reload nginx
#   5) sudo certbot --nginx -d remotix.hlsistemas.com   (anade TLS 443 + redirect 80->443)

server {
    listen 80;
    listen [::]:80;
    server_name remotix.hlsistemas.com;

    # Consola web compilada (ver DEPLOY.md, paso 1 del modo Nginx).
    root /var/www/remotix;
    index index.html;

    # Adjuntos de chat (el server admite hasta 50 MB).
    client_max_body_size 60m;

    # WebSockets: senalizacion WebRTC (/ws/signal), chat (/ws/chat) y
    # dispositivos Lite (/ws/device). Requieren el upgrade de conexion.
    location /ws/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # API REST, healthcheck y descargas del agente -> server Node.
    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    location = /health {
        proxy_pass http://127.0.0.1:8080;
    }
    location /download/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
    }

    # Resto -> SPA (rutas de React Router).
    location / {
        try_files $uri $uri/ /index.html;
    }
}
