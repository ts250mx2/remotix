# Configuración de despliegue de Remotix (cópialo a .env y rellénalo).
# Usado por docker-compose.yml.

# Dominio público de la consola (DNS A → IP de este servidor).
DOMAIN=soporte.tudominio.com

# Email para los avisos de Let's Encrypt.
ACME_EMAIL=tu-email@tudominio.com

# Secreto para firmar las cookies de sesión del portal. Genera uno aleatorio:
#   openssl rand -hex 32
SESSION_SECRET=

# Secreto compartido para las credenciales TURN efímeras (server ↔ coturn).
# Genera otro distinto:
#   openssl rand -hex 32
TURN_SECRET=
